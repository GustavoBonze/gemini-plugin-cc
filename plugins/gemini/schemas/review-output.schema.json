{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GeminiReviewOutput",
  "type": "object",
  "additionalProperties": false,
  "required": ["verdict", "summary", "findings", "next_steps"],
  "properties": {
    "verdict": {
      "type": "string",
      "enum": ["approve", "needs-attention"]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["severity", "file", "line_start", "line_end", "title", "body", "recommendation", "confidence"],
        "properties": {
          "severity": {
            "type": "string",
            "enum": ["critical", "high", "medium", "low"]
          },
          "file": { "type": "string", "minLength": 1 },
          "line_start": { "type": "integer", "minimum": 1 },
          "line_end": { "type": "integer", "minimum": 1 },
          "title": { "type": "string", "minLength": 1 },
          "body": { "type": "string", "minLength": 1 },
          "recommendation": { "type": "string" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    },
    "next_steps": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "artifacts": {
      "type": "array",
      "description": "Optional supplementary outputs: suggested patches, config snippets, migration scripts",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["kind", "title", "content"],
        "properties": {
          "kind": {
            "type": "string",
            "enum": ["patch", "config", "script", "note"]
          },
          "title": { "type": "string", "minLength": 1 },
          "content": { "type": "string" }
        }
      }
    }
  }
}
